nu X. [liftButton_1](mu Y. [!open_1]Y && <true>true) && [liftButton_2](mu Z1. [!open_2]Z1 && <true>true) && [liftButton_3](mu X2. [!open_3]X2 && <true>true) && [liftButton_4](mu Y2. [!open_4]Y2 && <true>true) && [liftButton_5](mu Z2. [!open_5]Z2 && <true>true) && [true]X